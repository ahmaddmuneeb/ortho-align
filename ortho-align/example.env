DATABASE_URL=""
JWT_SECRET=""
PORT=8000
NODE_ENV=production

# --- AWS S3 (required for file uploads) ---
# Option A (recommended on EC2): attach an IAM role to the instance — only set bucket + region.
# Option B: create an IAM user with S3 access and set all four variables below.

AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=orthoalign-production

# Only needed if NOT using an EC2 IAM instance role:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Password reset emails ---
# URL of the frontend (portal) — used to build the reset-password link
FRONTEND_URL=http://localhost:5173

# SMTP creds for sending emails. If unset, reset links are logged to the server console instead of emailed (dev fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OrthoAlign <no-reply@orthoalignsolution.com>"
